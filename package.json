{
  "name": "song-explorer",
  "version": "1.0.0",
  "description": "Ukulele Tuesday Song Explorer - browse and search song sheets",
  "devDependencies": {
    "astro": "^6.0.8",
    "vitest": "^4.1.1"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "astro dev",
    "build": "pnpm download-data && astro build",
    "preview": "astro preview",
    "download-data": "curl -fsSL 'https://ukulele-tuesday-datasets.storage.googleapis.com/song-sheets/aggregated/latest/data.jsonl' -o public/data.jsonl",
    "clean": "rm -rf dist/ public/data.jsonl"
  },
  "dependencies": {
    "lunr": "^2.3.9"
  }
}
