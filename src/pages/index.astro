---
import '../styles/styles.css';

const base = import.meta.env.BASE_URL; // used for static asset paths in template
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ukulele Tuesday – Song Sheets</title>

  <!-- SEO Meta Tags -->
  <meta name="description" content="Browse and search all Ukulele Tuesday song sheets. Free ukulele chord sheets from Dublin's favourite ukulele club.">
  <meta name="keywords" content="ukulele, song sheets, ukulele tuesday, dublin, music, chords">
  <meta name="author" content="Ukulele Tuesday">
  <meta name="robots" content="index, follow">

  <!-- Social Media Meta Tags -->
  <meta property="og:title" content="Ukulele Tuesday – Song Sheets">
  <meta property="og:description" content="Browse and search all Ukulele Tuesday song sheets. Free ukulele chord sheets from Dublin's favourite ukulele club.">
  <meta property="og:image" content="https://songbooks.ukuleletuesday.ie/assets/uke-closeup.jpeg">
  <meta property="og:url" content="https://ukuleletuesday.github.io/songs/">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Ukulele Tuesday – Song Sheets">
  <meta name="twitter:description" content="Browse and search all Ukulele Tuesday song sheets. Free ukulele chord sheets from Dublin's favourite ukulele club.">
  <meta name="twitter:image" content="https://songbooks.ukuleletuesday.ie/assets/uke-closeup.jpeg">

  <link rel="icon" href="https://songbooks.ukuleletuesday.ie/assets/favicon.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Pattaya&display=swap" rel="stylesheet">
  <script src="../scripts/explorer.js"></script>
</head>
<body>

<div class="container">

<header>
  <img src={`${base}/ut-logo-wordmark.svg`} alt="Ukulele Tuesday" class="header-logo">
  <div class="header-text">
    <h1>Song Explorer</h1>
    <p class="header-tagline">Browse <span id="header-count-inline"></span> ukulele songs</p>
  </div>
</header>

  <div class="controls">
    <!-- Search -->
    <div class="search-wrapper">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59
                 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5
                 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
      </svg>
      <input id="search" type="search" placeholder="Search songs, artists, chords…" autocomplete="off"
             aria-label="Search song sheets" />
    </div>

    <!-- Difficulty filter (calibrated to actual range: 0.81–5.03) -->
    <!-- Sort by -->
    <div class="filter-group">
      <label for="sort-by">Sort by</label>
      <select id="sort-by" aria-label="Sort songs">
        <option value="title">Title (A–Z)</option>
        <option value="last-added">Last added</option>
      </select>
    </div>

    <button class="btn-clear" id="btn-clear" aria-label="Clear all filters">✕ Clear</button>

    <!-- Difficulty filter (pills, populated at runtime from the dataset) -->
    <div class="filter-group filter-group-tags">
      <label id="difficulty-filter-label">Difficulty</label>
      <div id="difficulty-filter" class="tag-filter" role="group" aria-labelledby="difficulty-filter-label"></div>
    </div>

    <!-- Country filter (flag pills, populated at runtime from the dataset) -->
    <div class="filter-group filter-group-tags">
      <label id="country-filter-label">Country</label>
      <div id="country-filter" class="tag-filter" role="group" aria-labelledby="country-filter-label"></div>
    </div>

    <!-- Theme filter (emoji pills, populated at runtime from the dataset) -->
    <div class="filter-group filter-group-tags">
      <label id="theme-filter-label">Theme</label>
      <div id="theme-filter" class="tag-filter" role="group" aria-labelledby="theme-filter-label"></div>
    </div>

    <!-- Genre filter (text pills, populated at runtime from the dataset) -->
    <div class="filter-group filter-group-tags">
      <label id="genre-filter-label">Genre</label>
      <div id="genre-filter" class="tag-filter" role="group" aria-labelledby="genre-filter-label"></div>
    </div>
  </div>

  <div class="stats-bar">
    <span class="count" id="result-count"></span>
  </div>

  <div id="loading">
    <div class="spinner" role="status" aria-label="Loading"></div>
    <p>Loading song sheets…</p>
  </div>

  <div id="error" hidden role="alert"></div>

  <div id="results" role="list" aria-label="Song sheets"></div>

  <footer>
    <img src="https://songbooks.ukuleletuesday.ie/assets/ut-logo.png" alt="Ukulele Tuesday Logo" class="logo">
    <p class="description">Ukulele Tuesday is a free Ukulele club and meetup. We meet every Tuesday at the Stag's Head, Dublin, Ireland. Find more info on our socials and websites below.</p>
    <p class="disclaimer">
      We claim no copyright on any of the songs in these song sheets (except our own). If someone has charged you for access to our content, please <a href="https://www.ukuleletuesday.ie/contact-us/" target="_blank" rel="noopener noreferrer">contact us</a>.
    </p>
    <div class="social-links">
      <a href="https://www.instagram.com/ukuleletuesday/" target="_blank" rel="noopener noreferrer" title="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      </a>
      <a href="https://www.youtube.com/@UkuleleTuesday" target="_blank" rel="noopener noreferrer" title="YouTube">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
      </a>
      <a href="https://ukuleletuesday.ie/" target="_blank" rel="noopener noreferrer" title="Website">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
      </a>
    </div>
  </footer>

</div>

</body>
</html>
