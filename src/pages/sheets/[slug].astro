---
import fs from 'node:fs';
import path from 'node:path';
import { slugify, difficultyBand, escHtml, buildBadges, renderBadge } from '../../utils/utils.js';
import '../../styles/styles.css';

export async function getStaticPaths() {
  let lines = [];
  try {
    lines = fs.readFileSync(path.resolve('public/data.jsonl'), 'utf8').trim().split('\n').filter(Boolean);
  } catch {
    return []; // graceful fallback when data.jsonl is absent (e.g. first dev run)
  }

  const seen = new Set();
  return lines.flatMap(line => {
    try {
      const song = JSON.parse(line);
      const p = song.properties || {};
      if (!p.song || !p.artist) return [];
      const slug = `${slugify(p.song)}-${slugify(p.artist)}`;
      if (seen.has(slug)) return [];
      seen.add(slug);
      return [{ params: { slug }, props: { song } }];
    } catch {
      return [];
    }
  });
}

const { song } = Astro.props;
const props = song.properties || {};
const base = import.meta.env.BASE_URL;

const encodedId = encodeURIComponent(song.id);
const pdfUrl = `https://storage.googleapis.com/songbook-generator-cache-europe-west1/song-sheets/${encodedId}.pdf`;
const title = `${props.song} – ${props.artist}`;
const description = `Ukulele chord sheet for "${props.song}" by ${props.artist}. Free chord sheet from Ukulele Tuesday.`;
const searchQuery = encodeURIComponent(`${props.song} ${props.artist}`);
const spotifyUrl = `https://open.spotify.com/search/${searchQuery}`;
const youtubeUrl = `https://www.youtube.com/results?search_query=${searchQuery}`;

const band = difficultyBand(props.difficulty);
const badges = buildBadges(props);
const badgesHtml = badges.map(b => renderBadge(b)).join('');

function metaRow(label, value) {
  return `<div class="meta-row"><span class="meta-label">${label}</span><span class="meta-value">${value}</span></div>`;
}

function generateMetadataRows(p) {
  const rows = [];

  if (p.artist) rows.push(metaRow('Artist', escHtml(p.artist)));

  if (p.chords) {
    const pills = p.chords.split(',')
      .map(c => c.trim()).filter(Boolean)
      .map(c => `<span class="chord-pill">${escHtml(c)}</span>`)
      .join('');
    rows.push(metaRow('Chords', `<span class="chord-pills">${pills}</span>`));
  }

  if (band) rows.push(metaRow('Difficulty',
    `<span class="chip chip-diff-${band}">${escHtml(props.difficulty)}</span>`));

  if (p.year)     rows.push(metaRow('Year',     escHtml(p.year)));
  if (p.language) rows.push(metaRow('Language', escHtml(p.language)));

  return rows.length ? `<div class="song-meta">${rows.join('')}</div>` : '';
}

const metadataRows = generateMetadataRows(props);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Social Media Meta Tags -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://songbooks.ukuleletuesday.ie/assets/uke-closeup.jpeg">
  <meta property="og:url" content={`https://ukuleletuesday.github.io/songs/sheets/${Astro.params.slug}/`}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://songbooks.ukuleletuesday.ie/assets/uke-closeup.jpeg">

  <link rel="icon" href="https://songbooks.ukuleletuesday.ie/assets/favicon.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Pattaya&display=swap" rel="stylesheet">
  <style>
    .btn-spotify {
      background: #1DB954;
      color: #fff;
      border: none;
    }

    .btn-spotify:hover {
      background: #1aa34a;
    }

    .btn-youtube {
      background: #FF0000;
      color: #fff;
      border: none;
    }

    .btn-youtube:hover {
      background: #cc0000;
    }

    .btn-youtube svg {
      width: 16px;
      height: 16px;
    }

    .btn-spotify svg {
      width: 16px;
      height: 16px;
    }

    .header-buttons {
      display: flex;
      gap: 0.75em;
      flex-wrap: wrap;
      align-self: flex-start;
    }

    .pdf-container {
      background: var(--card-bg);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      border: 1px solid #eee;
      margin-bottom: 2em;
    }

    embed {
      width: 100%;
      height: 1100px;
      min-height: 1100px;
    }

    .pdf-fallback {
      padding: 2rem;
      text-align: center;
      color: var(--text-muted);
      display: none;
    }

    .pdf-fallback.visible {
      display: block;
    }

    .pdf-fallback p {
      margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
      .song-controls {
        flex-direction: column;
        align-items: flex-start;
      }

      embed {
        height: 900px;
        min-height: 900px;
      }

      .btn {
        font-size: 0.9rem;
        padding: 8px 12px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <a href={base}><img src={`${base}/ut-logo-wordmark.svg`} alt="Ukulele Tuesday" class="header-logo"></a>
      <div class="header-text">
        <h1>Song Explorer</h1>
      </div>
      <a href={base} class="btn btn-secondary" title="Back to songs">← Back</a>
    </header>

    <div class="controls song-controls">
      <div class="song-info">
        <div class="song-title">
          {props.song}<Fragment set:html={badgesHtml ? ` ${badgesHtml}` : ''} />
        </div>
        <Fragment set:html={metadataRows} />
      </div>
      <div class="header-buttons">
        <a href={spotifyUrl} target="_blank" rel="noopener noreferrer" class="btn btn-spotify" title="Find on Spotify">
          <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 1 1-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 0 1 .207.857zm1.223-2.722a.78.78 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.52.781.781 0 0 1 .52-.972c3.632-1.102 8.147-.568 11.233 1.329a.78.78 0 0 1 .257 1.072zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 1 1-.543-1.794c3.532-1.072 9.404-.865 13.115 1.338a.937.937 0 0 1-.955 1.613z"/>
          </svg>
          Spotify
        </a>
        <a href={youtubeUrl} target="_blank" rel="noopener noreferrer" class="btn btn-youtube" title="Find on YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          YouTube
        </a>
        <button class="btn btn-icon" id="share-btn" title="Share song">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
          </svg>
          Share
        </button>
        <a href={pdfUrl} target="_blank" rel="noopener noreferrer" class="btn btn-icon" title="Download PDF">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download
        </a>
      </div>
    </div>

    <div class="pdf-container">
      <embed id="pdf-embed" src={pdfUrl} type="application/pdf" title={title}>
      <div class="pdf-fallback" id="pdf-fallback">
        <p>📄 PDF couldn't be displayed inline.</p>
        <a href={pdfUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          📥 Download PDF
        </a>
      </div>
    </div>

    <footer>
      <img src="https://songbooks.ukuleletuesday.ie/assets/ut-logo.png" alt="Ukulele Tuesday Logo" class="logo">
      <p class="description">Ukulele Tuesday is a free Ukulele club and meetup. We meet every Tuesday at the Stag's Head, Dublin, Ireland. Find more info on our socials and websites below.</p>
      <p class="disclaimer">
        We claim no copyright on any of the songs in these song sheets (except our own). If someone has charged you for access to our content, please <a href="https://www.ukuleletuesday.ie/contact-us/" target="_blank" rel="noopener noreferrer">contact us</a>.
      </p>
      <div class="social-links">
        <a href="https://www.instagram.com/ukuleletuesday/" target="_blank" rel="noopener noreferrer" title="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="https://www.youtube.com/@UkuleleTuesday" target="_blank" rel="noopener noreferrer" title="YouTube">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
        </a>
        <a href="https://ukuleletuesday.ie/" target="_blank" rel="noopener noreferrer" title="Website">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        </a>
      </div>
    </footer>
  </div>

  <script>
    // Show fallback only if PDF fails to load
    const embed = document.getElementById('pdf-embed');
    const fallback = document.getElementById('pdf-fallback');

    const timeout = setTimeout(() => {
      if (!embed.offsetHeight || embed.offsetHeight === 0) {
        fallback.classList.add('visible');
      }
    }, 1000);

    embed.addEventListener('load', () => {
      clearTimeout(timeout);
    });

    embed.addEventListener('error', () => {
      clearTimeout(timeout);
      fallback.classList.add('visible');
    });

    // Share button functionality
    const shareBtn = document.getElementById('share-btn');
    if (shareBtn) {
      shareBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const url = window.location.href;
        const title = document.title;

        if (navigator.share) {
          navigator.share({
            title: title,
            url: url,
          }).catch(err => {
            if (err.name !== 'AbortError') console.error('Share failed:', err);
          });
        } else {
          navigator.clipboard.writeText(url);
          shareBtn.style.opacity = '0.5';
          setTimeout(() => shareBtn.style.opacity = '', 300);
        }
      });
    }
  </script>
</body>
</html>
